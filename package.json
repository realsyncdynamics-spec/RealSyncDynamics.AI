{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "build:full": "vite build && npm run prerender",
    "prerender": "node scripts/prerender.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:db": "bash -c 'export TEST_DB_URL=$(bash scripts/test-db/up.sh) && echo \"Using $TEST_DB_URL\" && vitest run test/runtime/db/ --no-file-parallelism'",
    "e2e": "playwright test",
    "test:e2e": "playwright test --config=playwright.catalog.config.ts",
    "test:e2e:ui": "playwright test --config=playwright.catalog.config.ts --ui",
    "test:e2e:report": "playwright show-report",
    "check:production": "node scripts/production-readiness-check.mjs",
    "smoke:production": "node scripts/smoke-production-routing.mjs",
    "diagnose:domain": "node scripts/diagnose-domain-routing.mjs",
    "check:edge-functions": "node scripts/check-edge-function-drift.mjs",
    "qa:skills": "tsx scripts/qa-skills-smoke.ts",
    "qa:governance": "tsx scripts/qa-governance-test.ts",
    "qa:governance-test": "tsx scripts/qa-governance-test.ts",
    "qa:smoke": "tsx scripts/qa-smoke-test.ts",
    "qa:load": "tsx scripts/qa-load-test.ts",
    "release:merge": "bash scripts/release-merge-deploy.sh",
    "release:publish": "bash scripts/publish-release.sh"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@react-pdf/renderer": "^4.5.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@sentry/react": "^8.55.2",
    "@supabase/supabase-js": "^2.105.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1",
    "three": "^0.184.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.2.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "@types/three": "^0.184.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.21",
    "fs-extra": "^11.3.5",
    "jsdom": "^29.1.1",
    "pg": "^8.21.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.5"
  }
}
