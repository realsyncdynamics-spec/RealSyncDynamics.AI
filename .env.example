# Local-development env-template. Copy to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.

# ──────────────── Required for the app to function ────────────────

# Supabase project URL (e.g. https://abcd1234.supabase.co)
VITE_SUPABASE_URL="MY_SUPABASE_URL"

# Supabase anon (public) key — safe to ship in the bundle
VITE_SUPABASE_ANON_KEY="MY_SUPABASE_ANON_KEY"

# ──────────────── AI provider keys ────────────────

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ──────────────── Optional — OAuth-Provider-Buttons (Auth) ────────────────
#
# Sichtbarkeit der Social-Login-Buttons auf /welcome + Checkout
# (src/features/auth/OAuthProviderButtons.tsx). Steuert NUR die UI —
# die eigentliche Provider-Aktivierung passiert im Supabase-Dashboard
# (Authentication → Providers). Setup pro Provider: docs/oauth-setup.md
#
# Semantik:
#   • Default ist AN — nur der explizite Wert "false" blendet einen Button aus.
#     So zeigt ein frisch deployter Stack ohne gesetzte Var weiterhin alle
#     eingerichteten Provider. Zum Ausblenden eines (noch) defekten Providers
#     ohne Redeploy: Flag im Hosting-Dashboard auf "false" setzen.
#   • Ausnahme LinkedIn: opt-IN — der Button erscheint NUR bei explizitem
#     "true", weil `linkedin_oidc` im Supabase-Projekt erst aktiviert werden
#     muss (sonst liefe der Klick in „Unsupported provider").
VITE_AUTH_GOOGLE_ENABLED="true"
VITE_AUTH_AZURE_ENABLED="true"
VITE_AUTH_GITHUB_ENABLED="true"
VITE_AUTH_LINKEDIN_ENABLED="false"

# ──────────────── Optional — observability ────────────────

# VITE_SENTRY_DSN: Sentry project DSN for error tracking.
# When unset, sentry init is a no-op (see src/lib/sentry.ts).
# Setup walkthrough: docs/runbooks/sentry-setup.md
# Format: https://<key>@<id>.ingest.de.sentry.io/<project-id>  (EU region)
VITE_SENTRY_DSN=""

# ──────────────── Optional — Stripe Billing ────────────────
#
# WICHTIG — maßgebliche Price-ID-Quelle zur Laufzeit ist die DATENBANK:
#   Die Edge-Function `stripe-checkout` löst die Stripe-Price-ID
#   ausschließlich aus `public.products.stripe_price_id`
#   (`default_for_plan_key`-Match) auf und verwirft Sentinel-Werte
#   (`internal_default_*`). Echte `price_…`-IDs werden per SQL geseedet:
#   siehe docs/runbooks/stripe-production-checkout.md
#   und docs/stripe-pricing-seed.template.sql.
#
# Die folgenden Frontend-Variablen sind die optionale, build-injizierte
# Convenience-Quelle (src/core/billing/stripe-mapping.ts) für UI-Zwecke und
# werden NICHT vom Checkout-Flow zur Preisermittlung gelesen. Beim Build von
# CI gesetzt (.github/workflows/deploy-cloudflare-pages.yml). Format je:
# "price_…" (Stripe → Products → <Tier> → Price ID).
VITE_STRIPE_PRICE_STARTER=""
VITE_STRIPE_PRICE_GROWTH=""
VITE_STRIPE_PRICE_AGENCY=""
VITE_STRIPE_PRICE_SCALE=""
VITE_STRIPE_PRICE_STARTER_YEARLY=""
VITE_STRIPE_PRICE_GROWTH_YEARLY=""
VITE_STRIPE_PRICE_AGENCY_YEARLY=""
VITE_STRIPE_PRICE_SCALE_YEARLY=""

# ──────────────── Server-only — Stripe Secrets (Edge Functions) ────────────────
# NUR in Supabase Edge-Function-Secrets / VPS-Env setzen — NIEMALS im Frontend
# (kein VITE_-Prefix → landet nicht im Bundle). Edge-Functions lesen primär
# Deno.env und fallen sonst auf `vault.secrets` zurück (get_app_secret RPC).
#   STRIPE_SECRET_KEY:     sk_live_… / sk_test_…  (stripe-checkout, stripe-portal)
#   STRIPE_WEBHOOK_SECRET: whsec_…               (stripe-webhook Signaturprüfung)
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
