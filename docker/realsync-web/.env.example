# .env Template für docker/realsync-web/
#
# Kopieren als .env neben docker-compose.yml:
#   cp .env.example .env
#
# Dann Werte einsetzen und `docker compose up -d` aufrufen.

# ─────────────────────────────────────────────────────────────────────────────
# TRAEFIK-INTEGRATION
# ─────────────────────────────────────────────────────────────────────────────

# TRAEFIK_NETWORK — Name des bestehenden Docker-Netzes des Host-Traefik.
# Auf dem VPS finden:  docker network ls | grep -iE 'traefik|proxy|web|openclaw'
# Typische Namen: 'openclaw_default', 'traefik_proxy', etc.
TRAEFIK_NETWORK=openclaw_default

# TRAEFIK_CERT_RESOLVER — Name des Let's-Encrypt-Resolvers in der Traefik
# Static Config (typisch 'letsencrypt'). Falls anders, in der Traefik-Config
# unter certificatesResolvers: nachschauen.
TRAEFIK_CERT_RESOLVER=letsencrypt

# ─────────────────────────────────────────────────────────────────────────────
# VITE BUILD-ARGS — landen als Umgebungsvariablen im statischen Bundle
# ─────────────────────────────────────────────────────────────────────────────

# VITE_SUPABASE_URL — URL eures Supabase Projects.
# Von: https://app.supabase.com → Project Settings → API Url
VITE_SUPABASE_URL=https://your-project.supabase.co

# VITE_SUPABASE_ANON_KEY — Public/Anon Key (NICHT der Service-Role Key!).
# Von: https://app.supabase.com → Project Settings → API → anon key
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# VITE_SENTRY_DSN — Error Tracking (Sentry). Optional; falls leer, Sentry disabled.
# Von: https://sentry.io → Project → Client Keys (DSN)
VITE_SENTRY_DSN=https://example@o1234567.ingest.sentry.io/1234567

# VITE_GOOGLE_GENAI_API_KEY — Google Generative AI Key für Gemini Integration.
# Generieren auf: https://ai.google.dev/
# Falls leer: Gemini-Features sind disabled.
VITE_GOOGLE_GENAI_API_KEY=AIzaSyD...

# VITE_STRIPE_PUBLISHABLE_KEY — Stripe Public Key für Payment-UI.
# Von: https://dashboard.stripe.com → API Keys → Publishable key
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─────────────────────────────────────────────────────────────────────────────
# DOMAIN CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# Primäre Domain — muss DNS A-Record haben der auf diese VPS IP zeigt:
#   realsyncdynamicsai.de  A  194.163.130.123 (beispiel)
#
# docker-compose.yml nutzt diese nicht direkt, aber Traefik-Labels referenzieren
# realsyncdynamicsai.de + www.realsyncdynamicsai.de. Falls diese DNS-Records
# noch nicht gesetzt sind, wird Traefik-Cert-Generation fehlschlagen.
# → DNS ZUERST konfigurieren, dann docker compose up -d.
