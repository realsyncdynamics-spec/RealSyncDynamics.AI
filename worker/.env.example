# Worker Environment — kopiere zu .env und fülle aus.
# Aktivierung siehe worker/README.md.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service-role-key-from-dashboard
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Worker-Identifikation
WORKER_ID=worker-1

# Playwright
PLAYWRIGHT_TIMEOUT_MS=30000

# Polling-Fallback (NOTIFY ist primär; Polling als safety net)
POLL_INTERVAL_MS=5000
