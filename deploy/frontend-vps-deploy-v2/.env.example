# frontend-vps-deploy-v2 — Beispiel-Env.
# Auf dem VPS nach .env kopieren und befüllen. NICHT committen.

# ── Build-Zeit (landet im SPA-Bundle, kein Geheimnis) ───────────────────────
VITE_SUPABASE_URL="https://<project>.supabase.co"
VITE_SUPABASE_ANON_KEY="<anon-key>"

# Optional — Sentry DSN. Leer lassen = Sentry-Init no-op.
VITE_SENTRY_DSN=""

# ── Runtime / Compose ───────────────────────────────────────────────────────
# Host-Port, auf dem der Container lauscht. Default 8090.
# Achten auf Kollisionen mit anderen Containern (openclaw-app-1) oder
# Host-Services (nginx 80/443, agent-runtime 8787).
FRONTEND_HOST_PORT=8090

# Image-Tag für Rollback-Strategien (z.B. git-sha oder release-version).
FRONTEND_IMAGE_TAG=latest
