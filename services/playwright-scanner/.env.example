# Playwright-Scanner — Environment-Konfiguration.
# Kopiere zu .env und setze die Werte. Niemals .env committen.

# REQUIRED — Bearer-Token den die Edge Function (cookie-scan-deep) sendet.
# Generieren via: openssl rand -hex 32
SCANNER_SECRET=change-me-to-a-32-byte-random-hex

# Optional — max parallele Scans (default: 10)
MAX_CONCURRENT=10

# Optional — Container-internal port (default: 3000)
PORT=3000

# ─── Traefik-Integration (nur falls docker-compose Traefik-Labels nutzt) ───
# BasicAuth-Hash; generieren via: htpasswd -nb user pass | sed -e s/\\$/\\$\\$/g
# Format: username:bcrypt-hash
TRAEFIK_BASIC_AUTH=
