# .env Template für deploy/static-subdomains/
#
# 1. Kopie als .env nebenan ablegen (cp .env.example .env).
# 2. TRAEFIK_NETWORK + TRAEFIK_CERT_RESOLVER aus deploy/ollama-traefik/.env
#    übernehmen — beides muss exakt identisch sein, sonst sieht Host-Traefik
#    die Container nicht.
# 3. docker compose up -d.

# Docker-Netz vom bestehenden Host-Traefik (identisch mit ollama-traefik).
TRAEFIK_NETWORK=openclaw_default

# Let's-Encrypt-Resolver-Name in der Host-Traefik-Konfiguration.
TRAEFIK_CERT_RESOLVER=letsencrypt

# Bind-Mount-Pfade auf der VPS-Disk. Defaults wie unten — anpassen falls
# anderes Volume-Layout. Pfade müssen vor dem ersten `up` existieren:
#   sudo mkdir -p /srv/realsyncdynamicsai/{cdn,preview,schemas}
#   sudo chown -R www-data:www-data /srv/realsyncdynamicsai
CDN_DISK_PATH=/srv/realsyncdynamicsai/cdn
PREVIEW_DISK_PATH=/srv/realsyncdynamicsai/preview
SCHEMAS_DISK_PATH=/srv/realsyncdynamicsai/schemas
