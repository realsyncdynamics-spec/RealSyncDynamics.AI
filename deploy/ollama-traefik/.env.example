# .env Template für deploy/ollama-traefik/
#
# 1. Kopie als .env nebenan ablegen (cp .env.example .env).
# 2. Werte einsetzen — siehe Kommentare unten.
# 3. docker compose up -d.

# ─────────────────────────────────────────────────────────────────────────────
# OLLAMA_BASIC_AUTH — BasicAuth-Credentials für ollama.realsyncdynamicsai.de
#
# Generieren auf dem VPS (apache2-utils muss installiert sein):
#   apt install -y apache2-utils
#   PASS=$(openssl rand -base64 24); \
#   echo "PASSWORD: $PASS"; \
#   htpasswd -nbB kodee "$PASS" | sed 's/\$/\$\$/g'
#
# Das `sed` doppelt die $-Zeichen, weil docker-compose sonst $apr1, $YYY etc.
# als Variablen interpretiert. Output dieser Zeile (Format: kodee:$$2y$$05$$...)
# direkt unten einsetzen. Das Klartext-Passwort merken — das schickt der
# Edge-Function-Client in OLLAMA_AUTH_TOKEN.
OLLAMA_BASIC_AUTH=kodee:$$2y$$05$$REPLACE_WITH_BCRYPT_HASH

# ─────────────────────────────────────────────────────────────────────────────
# WEBUI_SECRET_KEY — Sitzungs-Secret für Open WebUI (chat.realsyncdynamicsai.de).
# Einfach random generieren:
#   openssl rand -hex 32
WEBUI_SECRET_KEY=

# ENABLE_SIGNUP — auf "true" lassen, bis Du Dich als ersten User registriert hast
# (= Admin), dann auf "false" setzen + docker compose up -d, damit niemand sonst
# Konten anlegen kann.
ENABLE_SIGNUP=true

# ─────────────────────────────────────────────────────────────────────────────
# TRAEFIK_NETWORK — der Name des bestehenden Docker-Netzes von Host-Traefik.
# Auf dem VPS finden: docker network ls | grep -iE 'traefik|proxy|web|openclaw'
TRAEFIK_NETWORK=openclaw_default

# TRAEFIK_CERT_RESOLVER — Name eures Let's-Encrypt-Resolvers in der bestehenden
# Traefik-Config (typisch 'letsencrypt'). Falls anders: in der Traefik-Static-
# Config nachschauen (traefik.yml unter certificatesResolvers:).
TRAEFIK_CERT_RESOLVER=letsencrypt

# ─────────────────────────────────────────────────────────────────────────────
# N8N_ENCRYPTION_KEY — verschlüsselt Workflow-Credentials in der n8n-internen DB.
# WICHTIG: Einmal generieren, dauerhaft konstant halten — sonst Credentials weg.
#   openssl rand -hex 32
N8N_ENCRYPTION_KEY=
