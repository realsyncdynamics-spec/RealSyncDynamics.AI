# frontend-vps-deploy-v2 — Beispiel-Env.
# Auf dem VPS nach .env kopieren und befüllen. NICHT committen.

# ── Build-Zeit (landet im SPA-Bundle, kein Geheimnis) ───────────────────────
VITE_SUPABASE_URL="https://<project>.supabase.co"
VITE_SUPABASE_ANON_KEY="<anon-key>"

# Optional — Sentry DSN. Leer lassen = Sentry-Init no-op.
VITE_SENTRY_DSN=""

# ── Runtime / Compose ───────────────────────────────────────────────────────
# Host-Bind-Adresse. Default 127.0.0.1 = nur lokal auf dem VPS erreichbar.
# Auf "0.0.0.0" (oder leer) setzen erst, wenn ein Reverse-Proxy davorsteht
# oder direkter Public-Expose explizit gewollt ist.
FRONTEND_HOST_BIND=127.0.0.1

# Host-Port. Default 8090. NICHT 8080 verwenden — das ist openclaw-app-1.
# Andere bekannte Belegungen: 80/443 (Host-nginx), 8787 (agent-runtime).
FRONTEND_HOST_PORT=8090

# Image-Tag für Rollback-Strategien (z.B. git-sha oder release-version).
FRONTEND_IMAGE_TAG=latest
