{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://realsyncdynamicsai.de/spec/runtime/policy.schema.json",
  "title": "RealSync Runtime Policy (RPS v1.0)",
  "description": "Machine-readable governance policy. See spec/runtime/policy-specification.md.",
  "type": "object",
  "required": ["spec_version", "policy", "conditions", "actions"],
  "additionalProperties": false,
  "properties": {
    "spec_version": { "type": "string", "pattern": "^1\\.[0-9]+$" },
    "policy": {
      "type": "object",
      "required": ["id", "name", "version", "type", "tenant_id", "status", "effective_from", "domain"],
      "additionalProperties": false,
      "properties": {
        "id":              { "type": "string", "pattern": "^[a-z][a-z0-9_]*$", "maxLength": 64 },
        "name":            { "type": "string", "minLength": 1, "maxLength": 256 },
        "version":         { "type": "integer", "minimum": 1 },
        "type":            { "type": "string", "enum": ["guard", "retention", "classification", "escalation"] },
        "tenant_id":       { "type": "string", "minLength": 1 },
        "status":          { "type": "string", "enum": ["draft", "active", "archived"] },
        "effective_from":  { "type": "string", "format": "date-time" },
        "effective_until": { "oneOf": [{ "type": "null" }, { "type": "string", "format": "date-time" }] },
        "domain":          { "type": "string", "enum": ["finance", "governance", "inventory", "ai", "platform", "agent", "evidence", "tax", "runtime"] }
      }
    },
    "conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "minProperties": 1,
        "maxProperties": 1,
        "description": "One clause per array entry. Supported operators in RPS §4."
      }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "string",
            "enum": [
              "refuse",
              "prepare_export",
              "require_human_review",
              "notify_owner",
              "notify_dpo"
            ]
          },
          {
            "type": "object",
            "minProperties": 1,
            "maxProperties": 1,
            "description": "Parameterised action: { action_name: { params } } or { set_retention: <int> } etc."
          }
        ]
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "author":       { "type": "string" },
        "jurisdiction": { "type": "string", "pattern": "^[A-Z]{2}(?:-[A-Z0-9]{1,3})?$" },
        "references": {
          "type": "array",
          "items": { "type": "string", "maxLength": 256 }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "policy": { "properties": { "type": { "const": "retention" } } } } },
      "then": {
        "properties": {
          "actions": {
            "type": "array",
            "items": {
              "type": "object",
              "propertyNames": { "enum": ["set_retention", "redact_after_days"] }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "policy": { "properties": { "type": { "const": "classification" } } } } },
      "then": {
        "properties": {
          "actions": {
            "type": "array",
            "items": {
              "type": "object",
              "propertyNames": { "enum": ["set_category", "set_severity", "set_gdpr", "set_ai_act"] }
            }
          }
        }
      }
    }
  ]
}
