# Playwright Scanner — Environment Variables
# Kopieren: cp .env.example .env && nano .env

# ──────────────────────────────────────────────────────────────────────────────
# PFLICHT: API-Key fuer den Scanner-Microservice
# Generieren: openssl rand -hex 32
# Dieser Key wird in Supabase Vault als PLAYWRIGHT_SCANNER_KEY gespeichert.
# ──────────────────────────────────────────────────────────────────────────────
SCANNER_API_KEY=REPLACE_WITH_STRONG_SECRET_openssl_rand_hex_32

# ──────────────────────────────────────────────────────────────────────────────
# Traefik BasicAuth (zusaetzlicher Schutz vor dem API-Key)
# Generieren: htpasswd -nb realsyncdynamics DEIN_PASSWORT
# Wichtig: $ in der .env mit $$ escapen (docker-compose quirk)
# Beispiel: realsyncdynamics:$$apr1$$xyz...
# ──────────────────────────────────────────────────────────────────────────────
TRAEFIK_BASIC_AUTH=realsyncdynamics:$$apr1$$REPLACE_WITH_HTPASSWD_OUTPUT

# ──────────────────────────────────────────────────────────────────────────────
# Optional: Max gleichzeitige Scans (Standard: 3)
# VPS mit 4GB RAM: 3 ist sicher, 4 moeglich
# VPS mit 2GB RAM: max 2 empfohlen
# ──────────────────────────────────────────────────────────────────────────────
MAX_CONCURRENT=3
