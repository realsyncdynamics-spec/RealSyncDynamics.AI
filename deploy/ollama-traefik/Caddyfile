# Caddy reverse-proxy + Bearer-Auth gate für den lokalen Ollama-Container.
#
# Eingehend:  http://kodee-ollama-proxy:8080/(api/chat|api/tags|)
# Ausgehend:  http://ollama:11434/...
#
# Ohne den Header `Authorization: Bearer <OLLAMA_AUTH_TOKEN>` → 401.
# /api/pull, /api/delete, etc. bleiben unsichtbar — wir whitelisten explizit.

{
	# Globale Caddy-Optionen
	admin off
	auto_https off  # TLS macht Traefik vor uns; wir sind nur HTTP intern
	persist_config off
}

:8080 {
	# Bearer-Check als named matcher. Die Substitution {$OLLAMA_AUTH_TOKEN}
	# kommt aus der ENV-Var, die docker-compose aus .env injiziert.
	@unauthorized {
		not header Authorization "Bearer {$OLLAMA_AUTH_TOKEN}"
	}
	respond @unauthorized 401 {
		body `{"error":"unauthorized"}`
		close
	}

	# Health: GET /
	handle / {
		header Content-Type application/json
		respond `{"service":"ollama-proxy","status":"ok"}` 200
	}

	# Whitelist nur die zwei Endpunkte, die das ai-invoke benutzt.
	handle /api/chat {
		# Strip the bearer header before forwarding — Ollama ignoriert sowieso,
		# aber sauberer ist's.
		request_header -Authorization
		reverse_proxy ollama:11434 {
			# Lange Inferenz auf CPU: bis zu 3 Min.
			transport http {
				dial_timeout 10s
				response_header_timeout 180s
				read_timeout 180s
			}
		}
	}

	handle /api/tags {
		request_header -Authorization
		reverse_proxy ollama:11434
	}

	# Catch-all: alles andere innerhalb der Bearer-Zone wird abgelehnt.
	handle {
		header Content-Type application/json
		respond `{"error":"not found"}` 404
	}

	# Mehr Logging als Default, damit man im docker-logs sieht was passiert.
	log {
		output stdout
		format json
		level INFO
	}
}
