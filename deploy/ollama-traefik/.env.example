# .env Template — KOPIE als .env nebenan ablegen, Werte einsetzen.
#
# OLLAMA_AUTH_TOKEN wird gleich beim Setup mit `openssl rand -hex 32` erzeugt.
# TRAEFIK_NETWORK ist der Name des Docker-Netzes, an dem dein Host-Traefik
# schon hängt. Üblich: 'traefik_proxy', 'web', 'proxy', 'edge'.
# Finden: `docker network ls | grep -iE 'traefik|proxy|web'`
#
# TRAEFIK_CERT_RESOLVER ist der Name deines Let's-Encrypt-Resolvers in der
# bestehenden Traefik-Konfig (in traefik.yml unter certificatesResolvers:).
# Default 'letsencrypt' — passe an, falls du einen anderen Namen nutzt.

OLLAMA_AUTH_TOKEN=
TRAEFIK_NETWORK=traefik_proxy
TRAEFIK_CERT_RESOLVER=letsencrypt
