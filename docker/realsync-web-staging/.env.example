# .env Template für docker/realsync-web-staging/
#
# STAGING-Deployment (test.realsyncdynamicsai.de)
# Identisch zur Production, aber mit Staging-Domain.
# Kopieren als .env und Werte eintragen.

TRAEFIK_NETWORK=openclaw_default
TRAEFIK_CERT_RESOLVER=letsencrypt

# Supabase (kann gleich sein wie Production, oder separates Project)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional
VITE_SENTRY_DSN=https://example@o1234567.ingest.sentry.io/1234567
VITE_GOOGLE_GENAI_API_KEY=AIzaSyD...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...  # Stripe TEST-Key für Staging!
