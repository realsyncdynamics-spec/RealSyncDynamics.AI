# Copy to .env and fill in. Never commit .env.

POSTGRES_URL=postgresql://audit:securepassword@postgres:5432/gdpr_audit
POSTGRES_PASSWORD=securepassword

REDIS_HOST=redis
REDIS_PORT=6379

# Optional — only needed once the Risk-Narrative LLM step is wired
OPENAI_API_KEY=

# AI Gateway endpoint of the parent platform (Supabase Edge Function).
# When set, the worker delegates risk-narrative generation to the
# central gateway instead of calling OpenAI directly.
AI_GATEWAY_URL=

NODE_ENV=production
