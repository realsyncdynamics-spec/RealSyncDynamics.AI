# OpenAI-Credentials
OPENAI_API_KEY=sk-replace-me

# Bearer-Token den Clients senden muessen.
# Generieren mit: openssl rand -hex 32
OPENCLAW_SECRET=replace-me-32-bytes-hex

# CORS-Whitelist (comma-separated, ohne trailing slash)
OPENCLAW_CORS_ORIGINS=https://realsyncdynamicsai.de,https://www.realsyncdynamicsai.de

# Per-IP Sliding-Window-Rate-Limit
OPENCLAW_RATE_LIMIT_PER_MIN=10

# Daily-Token-Cap (alle Requests zusammen). Default 2M = ~$0.30 bei gpt-4o-mini
OPENCLAW_DAILY_TOKEN_CAP=2000000

# Optional: Sentry-DSN. No-op wenn leer.
SENTRY_DSN=

# Server-Port
PORT=3001
