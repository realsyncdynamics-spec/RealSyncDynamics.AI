{
  "name": "@realsync/openclaw-agent",
  "version": "0.1.0",
  "description": "OpenClaw Compliance-Agent — Hono + OpenAI + WebSocket. Härtungs-Build aus docs/openclaw-agent-spec.md mit Bearer-Auth, Rate-Limit, CORS-Whitelist, Cost-Cap, Sentry-Hook und Tool-Calling-Struktur.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --packages=external --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@sentry/node": "^8.55.2",
    "hono": "^4.6.14",
    "openai": "^4.77.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.24.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
