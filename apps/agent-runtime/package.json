{
  "name": "realsync-agent-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Controlled runtime gateway for RealSyncDynamics governance agents.",
  "type": "module",
  "main": "dist/gateway.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/gateway.js",
    "dev": "tsx watch src/gateway.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx ./test/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  }
}
