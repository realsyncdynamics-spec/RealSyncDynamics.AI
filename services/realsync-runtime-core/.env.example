# realsync-runtime-core — Umgebungsvariablen
# Kopieren nach .env und Werte setzen. Niemals echte Secrets committen.

# ── Laufzeit ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
LOG_LEVEL=info

# ── Interne Auth ─────────────────────────────────────────────────────────────
# Geteilter Schluessel fuer interne Service-zu-Service-Calls (Gateway/Evidence).
GATEWAY_INTERNAL_API_KEY=
# Secret zum Signieren/Pruefen der JWTs.
JWT_SECRET=

# ── Datenbank (Postgres) ─────────────────────────────────────────────────────
# Eigene Runtime-Core-DB (NICHT die Supabase-App-DB).
RUNTIME_CORE_DATABASE_URL=postgres://user:pass@postgres:5432/runtime_core

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── NATS (Event-Bus) ─────────────────────────────────────────────────────────
NATS_URL=nats://nats:4222
NATS_USER=realsync-core
NATS_PASSWORD=

# ── Evidence-Runtime (optional) ──────────────────────────────────────────────
EVIDENCE_RUNTIME_URL=http://realsync-evidence-runtime:5000

# ── Traefik (vom Compose-Stack genutzt) ──────────────────────────────────────
TRAEFIK_NETWORK=traefik_proxy
TRAEFIK_CERT_RESOLVER=letsencrypt
